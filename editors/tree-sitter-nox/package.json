{
  "name": "tree-sitter-nox",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Nox programming language",
  "license": "MIT",
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "parser",
    "lexer",
    "nox"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nox-lang/nox"
  },
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**"
  ],
  "dependencies": {
    "node-addon-api": "^8.0.0",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "0.26.11"
  },
  "scripts": {
    "install": "node-gyp-build",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse",
    "generate": "tree-sitter generate"
  },
  "tree-sitter": [
    {
      "scope": "source.nox",
      "file-types": [
        "nox"
      ],
      "highlights": "queries/highlights.scm"
    }
  ]
}
