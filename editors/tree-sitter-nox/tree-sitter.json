{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "nox",
      "camelcase": "Nox",
      "scope": "source.nox",
      "path": ".",
      "file-types": [
        "nox"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^nox$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Nox programming language",
    "authors": [
      {
        "name": "Nox dili katkıcıları"
      }
    ],
    "links": {
      "repository": "https://github.com/mburakmmm/nox-lang"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": true,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
