{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "noxc: -g ile derle",
      "type": "shell",
      // `zig-out/bin/noxc`nin proje köküne göre YOLU — kendi kurulumunuza
      // göre düzenleyin (bkz. README.md).
      "command": "${workspaceFolder}/zig-out/bin/noxc",
      "args": ["build", "-g", "${file}"],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
