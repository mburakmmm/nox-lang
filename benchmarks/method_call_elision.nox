class Counter:
    def __init__(self: Counter, start: int) -> None:
        self.value = start

    def increment(self: Counter, amount: int) -> int:
        self.value = self.value + amount
        return self.value

def run(n: int) -> int:
    c: Counter = Counter(0)
    i: int = 0
    while i < n:
        c.increment(1)
        i = i + 1
    return c.value

print(run(300000000))
