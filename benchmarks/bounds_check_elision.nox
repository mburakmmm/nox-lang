def sum_indexed(xs: list[int]) -> int:
    total: int = 0
    for i in range(len(xs)):
        total = total + xs[i]
    return total

def run(n: int) -> int:
    xs: list[int] = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5, 8, 9, 7, 9, 3, 2, 3, 8, 4]
    total: int = 0
    i: int = 0
    while i < n:
        total = total + sum_indexed(xs)
        i = i + 1
    return total

print(run(5000000))
