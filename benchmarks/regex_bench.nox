import nox.regex

def churn(n: int) -> int:
    count: int = 0
    i: int = 0
    while i < n:
        if nox.regex.is_match("a*b", "aaaaaaaaaab"):
            count = count + 1
        if nox.regex.find("[0-9]+", "abc123def456") >= 0:
            count = count + 1
        if nox.regex.is_match("^[a-z]+$", "hello"):
            count = count + 1
        i = i + 1
    return count

print(churn(50000))
