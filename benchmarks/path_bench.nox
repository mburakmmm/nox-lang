import nox.path

def churn(n: int) -> int:
    total: int = 0
    i: int = 0
    while i < n:
        p: str = nox.path.join("/usr/local/bin", "nox")
        b: str = nox.path.basename(p)
        d: str = nox.path.dirname(p)
        e: str = nox.path.extension("archive.tar.gz")
        total = total + len(p) + len(b) + len(d) + len(e)
        if nox.path.is_absolute(p):
            total = total + 1
        i = i + 1
    return total

print(churn(100000))
