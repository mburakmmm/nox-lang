class NeverRaised:
    def __init__(self: NeverRaised, value: int) -> None:
        self.value = value

def maybe_raise(x: int) -> int:
    if x < 0:
        raise NeverRaised(x)
    return x + 1

def run(n: int) -> int:
    total: int = 0
    i: int = 0
    while i < n:
        total = total + maybe_raise(1)
        i = i + 1
    return total

print(run(300000000))
