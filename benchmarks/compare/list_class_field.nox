class Box:
    def __init__(self: Box, items: list[int]) -> None:
        self.items = items

    def sum(self: Box) -> int:
        local_items: list[int] = self.items
        total: int = 0
        for x in local_items:
            total = total + x
        return total

def compute(n: int) -> int:
    b: Box = Box([1, 2, 3, 4, 5, 6, 7, 8])
    total: int = 0
    i: int = 0
    while i < n:
        total = total + b.sum()
        i = i + 1
    return total

print(compute(300000))
