import nox.math

def churn(n: int) -> float:
    total: float = 0.0
    i: int = 0
    while i < n:
        x: float = sqrt(i + 1.0)
        y: float = pow(x, 2.0)
        z: float = floor(y) + ceil(y)
        total = total + nox.math.max(z, nox.math.min(x, y)) + nox.math.abs(x - y)
        i = i + 1
    return total

print(churn(100000))
