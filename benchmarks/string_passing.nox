def pick(i: int) -> str:
    if i % 3 == 0:
        return "alpha"
    if i % 3 == 1:
        return "beta"
    return "gamma"

def pass_through(s: str) -> str:
    return s

def compute(n: int) -> int:
    count: int = 0
    i: int = 0
    while i < n:
        s: str = pass_through(pass_through(pick(i)))
        if i % 3 == 0:
            count = count + 1
        i = i + 1
    return count

print(compute(20000000))
