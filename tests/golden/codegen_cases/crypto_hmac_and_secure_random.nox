import nox.crypto

print(nox.crypto.hmac_sha256("Jefe", "what do ya want for nothing?"))
print(nox.crypto.constant_time_eq("gizli", "gizli"))
print(nox.crypto.constant_time_eq("gizli", "farkli"))

t1: str = nox.crypto.secure_random_hex(16)
print(len(t1))
t2: str = nox.crypto.secure_random_hex(16)
print(t1 == t2)
