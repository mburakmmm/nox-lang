class Boom:
    def __init__(self: Boom, message: str) -> None:
        self.message = message

class Resource:
    def __init__(self: Resource, name: str) -> None:
        self.name = name

    def __enter__(self: Resource) -> str:
        return self.name

    def __exit__(self: Resource) -> None:
        print("exit")

def use() -> None:
    with Resource("x") as name:
        raise Boom("bad")

try:
    use()
except Boom as e:
    print("caught")
    print(e.message)
