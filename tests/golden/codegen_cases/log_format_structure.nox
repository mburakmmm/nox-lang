import nox.log
import nox.strings

debug_line: str = nox.log.format("DEBUG", "starting up")
info_line: str = nox.log.format("INFO", "all good")
warn_line: str = nox.log.format("WARN", "careful")
error_line: str = nox.log.format("ERROR", "boom")

print(nox.strings.starts_with(debug_line, "[DEBUG] ["))
print(nox.strings.contains(debug_line, "] starting up"))
print(nox.strings.starts_with(info_line, "[INFO] ["))
print(nox.strings.contains(info_line, "] all good"))
print(nox.strings.starts_with(warn_line, "[WARN] ["))
print(nox.strings.contains(warn_line, "] careful"))
print(nox.strings.starts_with(error_line, "[ERROR] ["))
print(nox.strings.contains(error_line, "] boom"))
