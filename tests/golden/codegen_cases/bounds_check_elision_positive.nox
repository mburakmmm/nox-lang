def sum_list(xs: list[int]) -> int:
    total: int = 0
    for i in range(len(xs)):
        total = total + xs[i]
    return total

def count_char(s: str, target: str) -> int:
    count: int = 0
    for i in range(len(s)):
        if s[i] == target:
            count = count + 1
    return count

print(sum_list([3, 1, 4, 1, 5, 9, 2, 6]))
print(count_char("banana", "a"))
