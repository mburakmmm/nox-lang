import nox.json

v: JsonValue = nox.json.decode("{\"a\": [1, 2, true, null, \"hi\"], \"b\": 3.5}")
print(nox.json.is_object(v))
print(nox.json.object_len(v))
print(nox.json.object_key(v, 0))

arr: JsonValue = nox.json.object_value(v, 0)
print(nox.json.is_array(arr))
print(nox.json.array_len(arr))
print(nox.json.as_number(nox.json.array_get(arr, 0)))
print(nox.json.as_number(nox.json.array_get(arr, 1)))
print(nox.json.as_bool(nox.json.array_get(arr, 2)))
print(nox.json.is_null(nox.json.array_get(arr, 3)))
print(nox.json.as_string(nox.json.array_get(arr, 4)))

print(nox.json.object_key(v, 1))
print(nox.json.as_number(nox.json.object_value(v, 1)))
