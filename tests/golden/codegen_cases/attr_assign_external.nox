class Point:
    def __init__(self: Point, x: int, y: int) -> None:
        self.x = x
        self.y = y

class Car:
    def __init__(self: Car, engine: Point) -> None:
        self.engine = engine

def move(p: Point, dx: int, dy: int) -> None:
    p.x = p.x + dx
    p.y = p.y + dy

def rebind_engine(c: Car, e: Point) -> None:
    c.engine = e

p: Point = Point(1, 2)
move(p, 10, 20)
print(p.x)
print(p.y)

car: Car = Car(Point(0, 0))
rebind_engine(car, Point(5, 5))
print(car.engine.x)
print(car.engine.y)
