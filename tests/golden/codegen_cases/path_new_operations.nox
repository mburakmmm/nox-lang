import nox.path

print(nox.path.canonicalize("/usr/../usr"))
print(nox.path.strip_prefix("/a/b/c.txt", "/a/b"))
print(nox.path.strip_prefix("/a/b/c.txt", "/x/y"))
comps: list[str] = nox.path.components("/a/b/c.txt")
print(len(comps))
print(comps[0])
print(comps[1])
print(comps[2])
try:
    bad: str = nox.path.canonicalize("/definitely/does/not/exist/nox_iii4")
    print("ulasilmamali")
except nox_path_PathError as e:
    print(e.message)
