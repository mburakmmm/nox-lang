import nox.json

v: JsonValue = nox.json.decode("{\"a\":1,\"b\":[1,2,3],\"c\":{\"x\":true,\"y\":null}}")
print(nox.json.encode_pretty(v, 2))

empty_arr: JsonValue = nox.json.decode("[]")
print(nox.json.encode_pretty(empty_arr, 2))

empty_obj: JsonValue = nox.json.decode("{}")
print(nox.json.encode_pretty(empty_obj, 4))

scalar: JsonValue = nox.json.decode("42")
print(nox.json.encode_pretty(scalar, 2))
