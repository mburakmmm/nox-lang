def count_two(s: str) -> int:
    total: int = 0
    i: int = 0
    while i < 6:
        if s[i] == "a":
            total = total + 1
        if s[i] == "n":
            total = total + 1
        i = i + 1
    return total

def count_via_for(s: str) -> int:
    total: int = 0
    for i in range(len(s)):
        if s[i] == "b":
            total = total + 1
    return total

print(count_two("banana"))
print(count_via_for("babble"))
