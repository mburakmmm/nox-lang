def make_pair() -> list[int]:
    return [3, 4]

def total(xs: list[int]) -> int:
    return xs[0] + xs[1]

def square(x: int) -> int:
    return x * x

def clamp(x: int) -> int:
    if x < 0:
        return 0
    return x

print(total(make_pair()))
print(square(6))
print(clamp(-5))
print(clamp(9))
