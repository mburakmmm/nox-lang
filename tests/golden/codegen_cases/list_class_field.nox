class Box:
    def __init__(self: Box, items: list[int]) -> None:
        self.items = items

    def sum(self: Box) -> int:
        local_items: list[int] = self.items
        total: int = 0
        for x in local_items:
            total = total + x
        return total

b: Box = Box([1, 2, 3])
print(b.sum())

c: Box = b
print(c.sum())

def make_box() -> Box:
    return Box([10, 20])

print(make_box().sum())
