xs: list[int] = [1, 2, 3, 4]
xs.append(5)
xs.append(6)
xs.append(7)
for x in xs:
    print(x)

# `ys`, xs KAPASİTESİ (4->8) BÜYÜDÜKTEN SONRA ama HENÜZ DOLMADAN (len 7 <
# cap 8) oluşturuldu — bu YÜZDEN bir SONRAKİ append (KAPASİTE YETERLİ,
# büyümesiz/hızlı yol) HER İKİ isimden de GÖRÜNÜR olmalıdır (gerçek
# paylaşım semantiği).
ys: list[int] = xs
xs.append(8)
print(ys[7])

xs[0] = 100
print(ys[0])
