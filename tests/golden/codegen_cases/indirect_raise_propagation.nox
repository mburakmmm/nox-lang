class MyError:
    def __init__(self: MyError, code: int) -> None:
        self.code = code

def level3(x: int) -> int:
    if x < 0:
        raise MyError(x)
    return x * 2

def level2(x: int) -> int:
    return level3(x) + 1

def level1(x: int) -> int:
    return level2(x) + 1

def compute(n: int) -> int:
    total: int = 0
    i: int = 0
    while i < n:
        try:
            total = total + level1(i - 5)
        except MyError as e:
            total = total + e.code
        i = i + 1
    return total

print(compute(10))
