import nox.strings

print(nox.strings.starts_with("hello", "he"))
print(nox.strings.starts_with("hello", "lo"))
print(nox.strings.ends_with("hello", "lo"))
print(nox.strings.ends_with("hello", "he"))
print(nox.strings.contains("hello", "ell"))
print(nox.strings.contains("hello", "xyz"))
print(nox.strings.index_of("hello", "l"))
print(nox.strings.index_of("hello", "z"))
print(nox.strings.index_of("hello", ""))
