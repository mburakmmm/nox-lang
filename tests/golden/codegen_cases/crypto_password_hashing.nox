import nox.crypto

pw: str = "correct horse battery staple"
wrong: str = "wrong password"

h1: str = nox.crypto.argon2_hash(pw)
print(nox.crypto.argon2_verify(h1, pw))
print(nox.crypto.argon2_verify(h1, wrong))
h1b: str = nox.crypto.argon2_hash(pw)
print(h1 == h1b)

h2: str = nox.crypto.bcrypt_hash(pw)
print(nox.crypto.bcrypt_verify(h2, pw))
print(nox.crypto.bcrypt_verify(h2, wrong))

h3: str = nox.crypto.scrypt_hash(pw)
print(nox.crypto.scrypt_verify(h3, pw))
print(nox.crypto.scrypt_verify(h3, wrong))

print(nox.crypto.argon2_verify("gecersiz-bir-dize", pw))
print(nox.crypto.bcrypt_verify("gecersiz-bir-dize", pw))
print(nox.crypto.scrypt_verify("gecersiz-bir-dize", pw))
