def classify(i: int) -> int:
    if i % 3 == 0:
        return 100
    if i % 3 == 1:
        return 200
    return 300

def tally(n: int) -> int:
    total: int = 0
    i: int = 0
    while i < n:
        total = total + classify(i)
        if i % 3 == 0:
            total = total + 1
        i = i + 1
    return total

print(tally(10))
