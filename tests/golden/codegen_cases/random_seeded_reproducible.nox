import nox.random

nox.random.seed(42)
a: int = nox.random.randint(1, 10)
print(a >= 1)
print(a <= 10)

f: float = nox.random.random()
print(f >= 0.0)
print(f < 1.0)

nox.random.seed(7)
x1: int = nox.random.randint(0, 100)
nox.random.seed(7)
x2: int = nox.random.randint(0, 100)
print(x1 == x2)

nox.random.seed(7)
y1: float = nox.random.random()
nox.random.seed(7)
y2: float = nox.random.random()
print(y1 == y2)
