def make_list() -> list[int]:
    return []

def take_list(ys: list[int]) -> int:
    return len(ys)

class Bag:
    items: list[int]
    def __init__(self: Bag) -> None:
        self.items = []

xs: list[int] = []
xs = [1, 2]
xs = []
xs.append(9)

b: Bag = Bag()

print(take_list([]))
print(len(make_list()))
print(len(xs))
print(xs[0])
print(len(b.items))
