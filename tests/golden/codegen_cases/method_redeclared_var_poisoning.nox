class A:
    def __init__(self: A) -> None:
        self.v = 1

    def get(self: A) -> int:
        return self.v

class B:
    def __init__(self: B) -> None:
        self.v = 2

    def get(self: B) -> int:
        return self.v

def pick(flag: bool) -> int:
    obj: A = A()
    if flag:
        obj: B = B()
    return obj.get()

print(pick(True))
print(pick(False))
