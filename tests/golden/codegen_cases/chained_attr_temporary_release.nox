class Engine:
    def __init__(self: Engine, hp: int) -> None:
        self.hp = hp

class Car:
    def __init__(self: Car, engine: Engine) -> None:
        self.engine = engine

def make_car(hp: int) -> Car:
    return Car(Engine(hp))

i: int = 0
total: int = 0
while i < 100:
    total = total + make_car(i).engine.hp
    i = i + 1
print(total)
