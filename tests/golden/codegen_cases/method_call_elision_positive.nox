class Adder:
    def __init__(self: Adder, base: int) -> None:
        self.base = base

    def inc(self: Adder, x: int) -> int:
        return x + self.base

    def double_inc(self: Adder, x: int) -> int:
        return self.inc(x) + self.inc(x)

def use_local(a: Adder, x: int) -> int:
    return a.double_inc(x)

a: Adder = Adder(10)
print(a.double_inc(5))
print(use_local(a, 3))
