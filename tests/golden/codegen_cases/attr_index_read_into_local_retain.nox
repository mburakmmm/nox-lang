class Engine:
    def __init__(self: Engine, hp: int) -> None:
        self.hp = hp

class Car:
    def __init__(self: Car, engine: Engine) -> None:
        self.engine = engine

c: Car = Car(Engine(100))

e1: Engine = c.engine
print(e1.hp)
c.engine = Engine(200)
print(e1.hp)

engines: list[Engine] = [Engine(1), Engine(2), Engine(3)]
e2: Engine = engines[1]
print(e2.hp)
engines = [Engine(9)]
print(e2.hp)
