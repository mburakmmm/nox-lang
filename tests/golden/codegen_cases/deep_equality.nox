class Point:
    def __init__(self: Point, x: int, y: int) -> None:
        self.x = x
        self.y = y

class Engine:
    def __init__(self: Engine, hp: int) -> None:
        self.hp = hp

class Car:
    def __init__(self: Car, engine: Engine) -> None:
        self.engine = engine

p1: Point = Point(1, 2)
p2: Point = Point(1, 2)
p3: Point = Point(3, 4)
print(p1 == p2)
print(p1 == p3)
print(p1 != p3)
print(p1 != p2)

a: list[int] = [1, 2, 3]
b: list[int] = [1, 2, 3]
c: list[int] = [1, 2, 4]
print(a == b)
print(a == c)
print(a != c)

s1: list[str] = ["hi", "there"]
s2: list[str] = ["hi", "there"]
s3: list[str] = ["hi", "you"]
print(s1 == s2)
print(s1 == s3)

n1: list[list[int]] = [[1, 2], [3, 4]]
n2: list[list[int]] = [[1, 2], [3, 4]]
n3: list[list[int]] = [[1, 2], [3, 5]]
print(n1 == n2)
print(n1 == n3)

e1: list[Engine] = [Engine(1), Engine(2)]
e2: list[Engine] = [Engine(1), Engine(2)]
e3: list[Engine] = [Engine(1), Engine(3)]
print(e1 == e2)
print(e1 == e3)

c1: Car = Car(Engine(100))
c2: Car = Car(Engine(100))
c3: Car = Car(Engine(200))
print(c1 == c2)
print(c1 == c3)
print(c1 != c3)

def make_point() -> Point:
    return Point(9, 9)

print(make_point() == Point(9, 9))
