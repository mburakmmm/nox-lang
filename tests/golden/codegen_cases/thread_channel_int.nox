import nox.thread

async def worker(tc: ThreadChannel[int]) -> None:
    i: int = 0
    while i < 5:
        await tc.send(i)
        i = i + 1

tc: ThreadChannel[int] = ThreadChannel[int](2)
h: ThreadHandle[None] = nox.thread.start(worker, tc)
i: int = 0
while i < 5:
    v: int = await tc.recv()
    print(v)
    i = i + 1
await h.join()
