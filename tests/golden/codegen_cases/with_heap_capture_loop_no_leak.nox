class Resource:
    def __init__(self: Resource, label: str) -> None:
        self.label = label

    def __enter__(self: Resource) -> str:
        return self.label

    def __exit__(self: Resource) -> None:
        pass

i: int = 0
while i < 5:
    combined: str = "resource_" + "x"
    with Resource(combined) as label:
        print(len(label))
    i = i + 1

print("done")
