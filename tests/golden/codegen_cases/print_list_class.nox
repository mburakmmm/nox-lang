class Point:
    def __init__(self: Point, x: int, y: int) -> None:
        self.x = x
        self.y = y

class Car:
    def __init__(self: Car, name: str, engine: Point) -> None:
        self.name = name
        self.engine = engine

p: Point = Point(1, 2)
print(p)

a: list[int] = [1, 2, 3]
print(a)

s: list[str] = ["hi", "there"]
print(s)

n: list[list[int]] = [[1, 2], [3, 4]]
print(n)

c: Car = Car("Toyota", Point(9, 9))
print(c)

lp: list[Point] = [Point(1, 1), Point(2, 2)]
print(lp)

single: list[int] = [1]
print(single)

print(Point(5, 6))

fl: list[float] = [1.5, 2.5]
print(fl)

print([True, False])
