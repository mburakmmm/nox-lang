xs: list[int] = [5, 3, 1, 4, 2]
xs.sort()
i: int = 0
while i < len(xs):
    print(xs[i])
    i = i + 1

ys: list[str] = ["banana", "apple", "cherry"]
ys.sort()
i = 0
while i < len(ys):
    print(ys[i])
    i = i + 1

zs: list[float] = [3.5, 1.1, 2.2]
zs.sort()
i = 0
while i < len(zs):
    print(zs[i])
    i = i + 1
