class Box:
    def __init__(self: Box, data: dict[str, str]) -> None:
        self.data = data

def make_boxes() -> Box:
    shared: dict[str, str] = {"key": "shared-value"}
    a: Box = Box(shared)
    b: Box = Box(shared)
    print(a.data["key"])
    print(b.data["key"])
    return a

box: Box = make_boxes()
print(box.data["key"])
