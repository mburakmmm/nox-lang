class Point:
    x: int
    y: int

    def __init__(self, x: int, y: int) -> None:
        self.x = x
        self.y = y

    def length_sq(self) -> int:
        return self.x * self.x + self.y * self.y

    def scale(self, factor: int) -> None:
        self.x = self.x * factor
        self.y = self.y * factor

p: Point = Point(3, 4)
print(p.length_sq())

p.scale(2)
print(p.x)
print(p.y)

q: Point = p
print(q.length_sq())
