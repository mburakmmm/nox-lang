x: int = 5
x += 3
print(x)
x -= 2
print(x)
x *= 4
print(x)
x //= 3
print(x)
x %= 5
print(x)

s: str = "a"
s += "b"
print(s)

name: str = "Ayse"
age: int = 30
print(f"merhaba {name}, {age} yasindasin")
print(f"duz metin")
print(f"")
print(f"escaped: {{not interpolated}}")

d: dict[str, str] = {"key": "val"}
print(f"{d['key']}")

b: bool = True
print(f"bool: {b}")
print(str(b))
print(str(False))
print(str(name))
