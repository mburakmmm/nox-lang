import nox.regex

print(nox.regex.is_match("^[0-9]+$", "12345"))
print(nox.regex.is_match("^[0-9]+$", "123a5"))
print(nox.regex.is_match("colou?r", "color"))
print(nox.regex.is_match("colou?r", "colour"))
print(nox.regex.find("wor.d", "hello world"))
print(nox.regex.find("xyz", "hello world"))
print(nox.regex.find("^hello", "hello world"))
