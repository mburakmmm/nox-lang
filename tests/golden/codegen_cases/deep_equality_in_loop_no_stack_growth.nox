class Point:
    def __init__(self: Point, x: int, y: int) -> None:
        self.x = x
        self.y = y

def count_equal(n: int) -> int:
    a: Point = Point(1, 2)
    b: Point = Point(1, 2)
    la: list[int] = [1, 2, 3, 4, 5, 6, 7, 8]
    lb: list[int] = [1, 2, 3, 4, 5, 6, 7, 8]
    total: int = 0
    i: int = 0
    while i < n:
        if a == b:
            total = total + 1
        if la == lb:
            total = total + 1
        i = i + 1
    return total

print(count_equal(2000000))
