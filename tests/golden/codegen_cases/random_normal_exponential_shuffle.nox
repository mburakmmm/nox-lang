import nox.random

nox.random.seed(42)

n1: float = nox.random.normal()
n2: float = nox.random.normal()
print(n1 != n2)
print(n1 > -100.0)
print(n1 < 100.0)

e1: float = nox.random.exponential(1.0)
print(e1 >= 0.0)

ints: list[int] = [1, 2, 3, 4, 5]
nox.random.shuffle(ints)
print(len(ints))
sum_after: int = ints[0] + ints[1] + ints[2] + ints[3] + ints[4]
print(sum_after)

strs: list[str] = ["a", "b", "c"]
nox.random.shuffle(strs)
print(len(strs))
print(strs[0] == "a" or strs[0] == "b" or strs[0] == "c")
print(strs[1] == "a" or strs[1] == "b" or strs[1] == "c")
print(strs[2] == "a" or strs[2] == "b" or strs[2] == "c")
