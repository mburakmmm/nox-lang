import nox.json

v1: JsonValue = nox.json.decode("{}")
print(nox.json.is_object(v1))
print(nox.json.object_len(v1))
print(nox.json.encode(v1))

v2: JsonValue = nox.json.decode("[]")
print(nox.json.is_array(v2))
print(nox.json.array_len(v2))
print(nox.json.encode(v2))

v3: JsonValue = nox.json.decode("{\"a\":[],\"b\":{}}")
print(nox.json.object_len(v3))
print(nox.json.array_len(nox.json.object_value(v3, 0)))
print(nox.json.object_len(nox.json.object_value(v3, 1)))
print(nox.json.encode(v3))
