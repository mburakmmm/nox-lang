import nox.uuid

id1: str = nox.uuid.uuid4()
id2: str = nox.uuid.uuid4()

print(len(id1))
print(id1 == id2)
print(nox.uuid.is_valid(id1))
print(nox.uuid.is_valid(id2))
print(id1[8])
print(id1[13])
print(id1[18])
print(id1[23])

print(nox.uuid.is_valid("not-a-uuid"))
print(nox.uuid.is_valid("12345678-1234-1234-1234-123456789012"))
print(nox.uuid.is_valid("12345678-1234-1234-X234-123456789012"))
print(nox.uuid.is_valid("12345678123412341234123456789012"))
