import nox.strings

print(nox.strings.trim_start("  hi  "))
print(nox.strings.trim_end("  hi  "))
parts: list[str] = nox.strings.splitn("a,b,c,d", ",", 2)
print(len(parts))
print(parts[0])
print(parts[1])
rparts: list[str] = nox.strings.rsplit("a,b,c", ",")
print(rparts[0])
print(rparts[1])
print(rparts[2])
print(nox.strings.repeat("ab", 3))
print(nox.strings.eq_ignore_case("Hello", "hello"))
print(nox.strings.eq_ignore_case("Hello", "world"))
