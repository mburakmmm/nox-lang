def sum_list(xs: list[int]) -> int:
    total: int = 0
    for v in xs:
        total = total + v
    return total

def make_list() -> list[int]:
    result: list[int] = [7, 8, 9]
    return result

original: list[int] = [1, 2, 3]
alias: list[int] = original
print(sum_list(original))
print(sum_list(alias))

built: list[int] = make_list()
print(sum_list(built))
