import nox.time

dt: nox_time_DateTime = nox_time_DateTime(2026, 7, 9, 4, 3, 5)
print(dt.to_str())

dt2: nox_time_DateTime = nox_time_DateTime(2026, 12, 31, 23, 59, 59)
print(dt2.to_str())

inst: nox_time_Instant = nox.time.instant_now()
nox.time.sleep_ms(20)
elapsed: int = inst.elapsed_ms()
print(elapsed >= 15)

dur: nox_time_Duration = inst.elapsed()
print(dur.as_ms() >= elapsed)
