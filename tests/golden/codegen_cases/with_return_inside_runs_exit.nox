class Resource:
    def __init__(self: Resource, name: str) -> None:
        self.name = name

    def __enter__(self: Resource) -> str:
        return self.name

    def __exit__(self: Resource) -> None:
        print("exit")

def use() -> int:
    with Resource("x") as name:
        return 42
    return 0

print(use())
print("after")
