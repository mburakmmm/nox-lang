d: dict[str, int] = {"a": 1, "b": 2, "c": 3}
ks: list[str] = d.keys()
vs: list[int] = d.values()
print(len(ks))
print(len(vs))
i: int = 0
while i < len(ks):
    print(ks[i])
    print(vs[i])
    i = i + 1

d2: dict[int, bool] = {1: True, 2: False}
bs: list[bool] = d2.values()
print(len(bs))
print(bs[0])
print(bs[1])

ints: dict[int, int] = {10: 100, 20: 200}
iks: list[int] = ints.keys()
print(iks[0])
print(iks[1])
