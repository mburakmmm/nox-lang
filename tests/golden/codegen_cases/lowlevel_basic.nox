class Point:
    def __init__(self: Point, x: int, y: int) -> None:
        self.x = x
        self.y = y

def compute() -> int:
    total: int = 0
    lowlevel:
        p: Point = Point(3, 4)
        total = p.x + p.y
        nums: list[int] = [1, 2, 3, 4, 5]
        i: int = 0
        while i < 5:
            total = total + nums[i]
            i = i + 1
    return total

print(compute())
