class MyError:
    def __init__(self: MyError, code: int) -> None:
        self.code = code

class Chain:
    def __init__(self: Chain, code: int) -> None:
        self.code = code

    def level3(self: Chain, x: int) -> int:
        if x < 0:
            raise MyError(self.code)
        return x * 2

    def level2(self: Chain, x: int) -> int:
        return self.level3(x) + 1

    def level1(self: Chain, x: int) -> int:
        return self.level2(x) + 1

def compute(n: int) -> int:
    c: Chain = Chain(99)
    total: int = 0
    i: int = 0
    while i < n:
        try:
            total = total + c.level1(i - 5)
        except MyError as e:
            total = total + e.code
        i = i + 1
    return total

print(compute(10))
