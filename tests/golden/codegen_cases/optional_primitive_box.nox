def safe_div(a: int, b: int) -> int | None:
    if b == 0:
        return None
    return a // b

def show(x: int | None) -> None:
    if x != None:
        print(x)
    else:
        print(-1)

show(safe_div(10, 2))
show(safe_div(7, 0))

y: int | None = 41
if y != None:
    z: int = y + 1
    print(z)

w: int | None = y
if w != None:
    print(w)
