class Box:
    def __init__(self: Box, v: int) -> None:
        self.value = v

    def get(self: Box) -> int:
        return self.value

def sum_boxes(boxes: list[Box]) -> int:
    total: int = 0
    for b in boxes:
        total = total + b.get()
    return total

boxes: list[Box] = [Box(1), Box(2), Box(3)]
print(sum_boxes(boxes))
