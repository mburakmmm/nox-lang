class Point:
    def __init__(self: Point, x: int, y: int) -> None:
        self.x = x
        self.y = y

def identity[T](x: T) -> T:
    return x

def first[T](xs: list[T]) -> T:
    return xs[0]

def pair_left[T, U](a: T, b: U) -> T:
    return a

nums: list[int] = [10, 20, 30]
print(identity(7))
print(identity("hello"))
print(first(nums))
print(pair_left(1, "x"))
print(pair_left("y", 2))

p: Point = identity(Point(3, 4))
print(p.x + p.y)
