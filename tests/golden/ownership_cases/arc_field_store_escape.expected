[modül]
  (heap tipli bağlama yok)
[metod Box.__init__]
  self: Box (parametre) -> ARC (parametre: fonksiyon sınırını zaten geçti)
    tahsis: parametre
    serbest: kapsam sonu
  seed: str (parametre) -> ARC (parametre: fonksiyon sınırını zaten geçti)
    tahsis: parametre
    serbest: kapsam sonu
  computed: str -> ARC (bir sınıf alanına atandığı için (self.<alan>))
    tahsis: var_decl
    serbest: kapsam sonu
