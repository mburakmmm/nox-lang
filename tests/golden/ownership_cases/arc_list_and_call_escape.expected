[modül]
  (heap tipli bağlama yok)
[fonksiyon process]
  item: str (parametre) -> ARC (parametre: fonksiyon sınırını zaten geçti)
    tahsis: parametre
    serbest: kapsam sonu
[fonksiyon build]
  a: str -> ARC (bir liste literaline eklendiği için)
    tahsis: var_decl
    serbest: kapsam sonu
  xs: list[str] -> ASAP (kapsam içinde kalıyor (kaçış tespit edilmedi))
    tahsis: var_decl
    serbest: kapsam sonu
  b: str -> ARC (bir çağrıya argüman olarak geçildiği için)
    tahsis: var_decl
    serbest: kapsam sonu
  c: str -> ASAP (kapsam içinde kalıyor (kaçış tespit edilmedi))
    tahsis: var_decl
    serbest: kapsam sonu
