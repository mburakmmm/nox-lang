(module
  (class Point
    (def __init__ (self:Point x:int y:int) None
      (assign (attribute (identifier self) x) (identifier x))
      (assign (attribute (identifier self) y) (identifier y))
    )
    (def length_sq (self:Point) int
      (return (binary add (binary mul (attribute (identifier self) x) (attribute (identifier self) x)) (binary mul (attribute (identifier self) y) (attribute (identifier self) y))))
    )
  )
)
