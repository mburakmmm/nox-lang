(module
  (async-def fetch (x:int) int
    (return (binary mul (identifier x) (int_lit 2)))
  )
  (async-def main () None
    (var_decl t Task[int] (spawn (call (identifier fetch) (int_lit 21))))
    (var_decl result int (await (identifier t)))
    (var_decl ch Channel[int] (generic_construct Channel[int] (int_lit 0)))
    (expr_stmt (await (call (attribute (identifier ch) send) (identifier result))))
  )
)
