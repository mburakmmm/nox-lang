class Node:
    value: int
    next: Node | None

    def __init__(self, value: int, next: Node | None) -> None:
        self.value = value
        self.next = next

def sum_list(head: Node | None) -> int:
    total: int = 0
    cur: Node | None = head
    while cur != None:
        total = total + cur.value
        cur = cur.next
    return total

n2: Node = Node(2, None)
n1: Node = Node(1, n2)
result: int = sum_list(n1)
