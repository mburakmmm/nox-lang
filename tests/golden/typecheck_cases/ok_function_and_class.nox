def add(a: int, b: int) -> int:
    return a + b

class Point:
    def __init__(self: Point, x: int, y: int) -> None:
        self.x = x
        self.y = y

    def length_sq(self: Point) -> int:
        return self.x * self.x + self.y * self.y

result: int = add(1, 2)
p: Point = Point(3, 4)
total: int = p.length_sq()
